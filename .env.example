# Copy to .env.local and adjust. Vite only exposes vars prefixed with VITE_.

# API root (must include /api/v1). Dev default: http://localhost:5000/api/v1
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Production — set when backend is deployed:
# VITE_API_BASE_URL=https://your-production-backend.example.com/api/v1

# Token refresh: path appended to VITE_API_BASE_URL, or a full https URL.
# VITE_AUTH_REFRESH_PATH=/auth/refresh

# If your API expects { "refresh_token": "..." } instead of refreshToken:
# VITE_AUTH_REFRESH_TOKEN_FIELD=refresh_token

# Web Push — must match backend VAPID_PUBLIC_KEY exactly.
# Generate: cd mecure-backend && npx web-push generate-vapid-keys
# Production requires HTTPS (localhost is OK for local dev).
# VITE_VAPID_PUBLIC_KEY=

# OneSignal (mobile Capacitor Android/iOS) — same App ID as backend ONESIGNAL_APP_ID
# Rebuild the APK after changing this (Vite embeds env at build time).
# VITE_ONESIGNAL_APP_ID=

# Legacy Capacitor FCM without OneSignal — only "true" with google-services.json.
# Prefer OneSignal (VITE_ONESIGNAL_APP_ID) for mobile.
# VITE_ANDROID_USE_NATIVE_FCM=true

# AI assistant: backend route that proxies to Gemini (never put API keys in the app).
# POST JSON { "message": string, "context": string } with Authorization: Bearer <access token>
# Response JSON { "reply": string } or { "message": string } or plain text.
# VITE_AI_CHAT_URL=https://your-backend.example.com/api/v1/ai/chat
